# ── アプリ ─────────────────────────────────────────────────────────────
PORT=3002
APP_URL=https://your-app.onrender.com
NODE_ENV=production

# ── データベース（Render Persistent Disk） ──────────────────────────────
DB_PATH=/data/shadowing.db

# ── Anthropic ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxxx
GENERATION_MODEL=claude-haiku-4-5

# ── OpenAI（TTS音声合成） ───────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxx

# ── JWT ────────────────────────────────────────────────────────────────
JWT_SECRET=your-very-long-random-secret-string-here

# ── Stripe ─────────────────────────────────────────────────────────────
# Stripeダッシュボードで取得
STRIPE_SECRET_KEY=sk_live_xxxx
STRIPE_PRICE_ID=price_xxxx          # ¥700/月 の価格ID
STRIPE_WEBHOOK_SECRET=whsec_xxxx    # Stripe CLI または Webhookエンドポイントから取得

# ── メール（SMTP） ─────────────────────────────────────────────────────
# 設定しない場合はコンソールに出力されます（開発環境）
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@email.com
SMTP_PASS=your-smtp-password
SMTP_FROM="English Shadowing AI" <noreply@shadowing-ai.app>
